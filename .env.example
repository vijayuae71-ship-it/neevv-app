# neevv Environment Variables
# Copy this to .env.local and fill in your values

# Google Cloud / Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here
GCP_PROJECT_ID=neev-491312
GCS_BUCKET_NAME=neevv-renders

# Firebase (Client-side - these are safe to expose)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=neev-491312.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=neev-491312
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=neev-491312.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (Server-side only)
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# App
NEXT_PUBLIC_APP_URL=https://neevv.com
NEXT_PUBLIC_APP_NAME=neevv
